{
  "name": "resume-copilot",
  "version": "1.0.0",
  "license": "MIT",
  "scripts": {
    "specs": "node --require ts-node/register/transpile-only specifications/runner/run-all.ts && npm run specs:infra && npm run specs:api && npm run specs:services",
    "specs:infra": "node --require ts-node/register/transpile-only specifications/infrastructure/extract-text.spec.ts",
    "specs:api": "node --require ts-node/register/transpile-only specifications/api/analyze-handler.spec.ts && node --require ts-node/register/transpile-only specifications/api/compare-handler.spec.ts",
    "specs:services": "node --require ts-node/register/transpile-only specifications/services/compare-resumes.spec.ts",
    "compare": "node --require ts-node/register/transpile-only specifications/reports/compare-v1-v2.ts",
    "analyze": "node --require ts-node/register/transpile-only cli/analyze.ts",
    "api": "node --require ts-node/register/transpile-only api/server.ts",
    "compare-resumes": "node --require ts-node/register/transpile-only cli/compare-resumes.ts"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.112.3",
    "express": "^5.2.1",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5"
  }
}
