{"nodes": [{"id": "adr_adr_001_deterministic_scoring_deterministic_scoring", "label": "Deterministic Scoring (ADR-001)", "file_type": "rationale", "source_file": "ADR/ADR-001-deterministic-scoring.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "El producto requiere resultados reproducibles, explicables y auditables. Confiar en un LLM para calcular scores genera opacidad, variabilidad y alucinaciones. Decisi\u00f3n: el score se calcula exclusivamente por reglas determin\u00edsticas en el backend; los LLMs solo explican, resumen y generan recomendaciones. Alternativa 'LLM calcula score' fue rechazada por falta de reproducibilidad y trazabilidad."}, {"id": "adr_adr_001_deterministic_scoring_algorithm_version", "label": "algorithmVersion", "file_type": "concept", "source_file": "ADR/ADR-001-deterministic-scoring.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "adr_adr_001_deterministic_scoring_pipeline_config", "label": "pipelineConfig", "file_type": "concept", "source_file": "ADR/ADR-001-deterministic-scoring.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}], "edges": [{"source": "adr_adr_001_deterministic_scoring_deterministic_scoring", "target": "especificacion_del_dominio_deterministic_scoring_principle", "relation": "conceptually_related_to", "confidence": "INFERRED", "confidence_score": 0.95, "source_file": "ADR/ADR-001-deterministic-scoring.md", "source_location": null, "weight": 1.0}, {"source": "adr_adr_001_deterministic_scoring_algorithm_version", "target": "especificacion_del_dominio_algorithmversion", "relation": "conceptually_related_to", "confidence": "INFERRED", "confidence_score": 0.85, "source_file": "ADR/ADR-001-deterministic-scoring.md", "source_location": null, "weight": 1.0}, {"source": "adr_adr_001_deterministic_scoring_pipeline_config", "target": "especificacion_del_dominio_pipelineconfig", "relation": "conceptually_related_to", "confidence": "INFERRED", "confidence_score": 0.95, "source_file": "ADR/ADR-001-deterministic-scoring.md", "source_location": null, "weight": 1.0}], "hyperedges": [{"id": "adr_deterministic_architecture_trio", "label": "ADR Trio Defining the Deterministic Analysis Architecture", "nodes": ["adr_adr_001_deterministic_scoring_deterministic_scoring", "adr_adr_002_analysis_model_analysis", "adr_adr_003_matchresult_evidence_matchresult"], "relation": "form", "confidence": "INFERRED", "confidence_score": 0.85, "source_file": "ADR/ADR-001-deterministic-scoring.md"}]}